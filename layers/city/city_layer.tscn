[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://layers/city/city_layer.gd" id="1"]

[sub_resource type="Environment" id="Environment_1"]
background_mode = 1
background_color = Color(0.004, 0.006, 0.018, 1)

; Ambient light — very subtle blue fill so shadows aren't pure black
ambient_light_source = 2
ambient_light_color = Color(0.015, 0.02, 0.06, 1)
ambient_light_energy = 0.12

; Tonemap — ACES filmic for cinematic contrast and color
tonemap_mode = 3
tonemap_exposure = 1.1
tonemap_white = 6.0

; Glow — multi-level bloom, controlled but visible
glow_enabled = true
glow_intensity = 0.8
glow_strength = 1.1
glow_bloom = 0.15
glow_hdr_threshold = 0.8
glow_hdr_scale = 2.0
glow_hdr_luminance_cap = 12.0
glow_blend_mode = 1

; Volumetric fog — subtle atmospheric haze, lights scatter through it
volumetric_fog_enabled = true
volumetric_fog_density = 0.012
volumetric_fog_albedo = Color(0.015, 0.015, 0.05, 1)
volumetric_fog_emission = Color(0.008, 0.006, 0.025, 1)
volumetric_fog_emission_energy = 0.4
volumetric_fog_anisotropy = 0.6
volumetric_fog_gi_inject = 0.3
volumetric_fog_temporal_reprojection_enabled = true
volumetric_fog_temporal_reprojection_amount = 0.9

; SDFGI — global illumination, light bounces off emissive surfaces
sdfgi_enabled = true
sdfgi_energy = 1.2
sdfgi_cascades = 6
sdfgi_bounce_feedback = 0.3

; SSR — reflective floor shows tower reflections
ssr_enabled = true
ssr_max_steps = 96
ssr_fade_in = 0.1
ssr_fade_out = 3.0
ssr_depth_tolerance = 0.5

; SSAO — deep contact shadows in corners and between towers
ssao_enabled = true
ssao_radius = 2.0
ssao_intensity = 3.0
ssao_light_affect = 0.3

; SSIL — screen-space indirect lighting, emissive surfaces light up nearby geometry
ssil_enabled = true
ssil_radius = 5.0
ssil_intensity = 1.0

; Adjustments — slight color correction for cinematic blue tint
adjustment_enabled = true
adjustment_brightness = 1.0
adjustment_contrast = 1.1
adjustment_saturation = 1.15

